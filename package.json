{
  "name": "tradninja",
  "version": "1.0.0",
  "type": "module",
  "sideEffects": false,
  "description": "Motor de traducao offline 100% local — 31 idiomas, 25k+ termos, cross-translate, zero internet",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "import": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    }
  },
  "files": ["src/"],
  "keywords": [
    "translation", "i18n", "offline", "localization",
    "portuguese", "english", "spanish", "french", "german",
    "japanese", "chinese", "korean", "arabic",
    "react", "react-native", "expo"
  ],
  "author": "clepta2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clepta2/tradninja"
  },
  "engines": { "node": ">=16.0.0" },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-native": ">=0.60.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.70.0",
    "typescript": "^5.0.0",
    "jest": "^29.0.0"
  }
}
