{
  "name": "tradninja",
  "version": "1.0.0",
  "type": "module",
  "sideEffects": false,
  "description": "Motor de traducao offline 100% local — PT/EN/ES com 36 modulos, zero internet",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "import": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    }
  },
  "files": ["src/"],
  "keywords": [
    "translation", "i18n", "offline", "localization",
    "portuguese", "english", "spanish",
    "react", "react-native", "expo"
  ],
  "author": "clepta2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clepta2/tradninja"
  },
  "engines": { "node": ">=16.0.0" }
}
